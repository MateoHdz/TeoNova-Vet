# ── Base de datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=veterinaria_pos
DB_CONNECTION_LIMIT=10

# ── JWT ───────────────────────────────────────────────────────
# IMPORTANTE: Cambiar por una cadena larga y aleatoria en producción
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_LARGO_Y_ALEATORIO_EN_PRODUCCION
JWT_EXPIRES_IN=8h

# ── Aplicación ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS: dominios permitidos (separados por coma) ────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ── Timezone ──────────────────────────────────────────────────
TZ=America/Bogota
# Offset MySQL para TypeORM (Colombia = -05:00)
DB_TIMEZONE=-05:00
# false después de ejecutar database/fix_sold_at_timezone.sql
SOLD_AT_LEGACY_UTC_CLOCK=true
