# Copiar a .env.docker y ajustar antes de: docker compose --env-file .env.docker up -d

# ── MySQL (servicio db) ───────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambiar_root_password_seguro
DB_NAME=veterinaria_pos
DB_USERNAME=vetapp
DB_PASSWORD=cambiar_password_app_seguro
DB_PORT_PUBLISH=3307

# ── Backend (leído por contenedor vetpos-api) ─────────────────
DB_HOST=db
DB_PORT=3306
DB_CONNECTION_LIMIT=10
DB_TIMEZONE=-05:00

JWT_SECRET=generar_con_openssl_rand_hex_64
JWT_EXPIRES_IN=8h

PORT=3001
NODE_ENV=production

# Origen público del navegador (puerto 80 por defecto)
CORS_ORIGINS=http://localhost,http://127.0.0.1

THROTTLE_TTL=60
THROTTLE_LIMIT=120

TZ=America/Bogota
SOLD_AT_LEGACY_UTC_CLOCK=true

# ── Frontend / Nginx ──────────────────────────────────────────
HTTP_PORT=80
